#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/lib/tv-target.sh
source "$script_dir/lib/tv-target.sh"

usage() {
  cat <<'USAGE'
Usage:
  scripts/play-spotify [--serial SERIAL] [--package PACKAGE] [--no-stop-media] SPOTIFY_URL

Launch a Spotify URL on the Shield through adb.

Options:
  -s, --serial SERIAL    adb device serial or HOST:PORT.
                         Defaults to TV_ADB_SERIAL, then .tv-serial, then ADB's selected device.
  -p, --package PACKAGE  Android package to receive the intent.
                         Defaults to com.spotify.tv.android.
  --no-stop-media        Do not force-stop known media apps before launch.
  --dry-run              Print the commands without invoking adb.
  -h, --help             Show this help.

Examples:
  scripts/play-spotify 'https://open.spotify.com/playlist/PLAYLIST_ID'
  scripts/play-spotify --dry-run 'https://open.spotify.com/playlist/PLAYLIST_ID'
USAGE
}

serial="$(tv_serial)"
package="com.spotify.tv.android"
target=""
dry_run=0
stop_media=1

while (($#)); do
  case "$1" in
    -s|--serial)
      if (($# < 2)); then
        echo "error: $1 requires a value" >&2
        exit 64
      fi
      serial="$2"
      shift 2
      ;;
    -p|--package)
      if (($# < 2)); then
        echo "error: $1 requires a value" >&2
        exit 64
      fi
      package="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --no-stop-media)
      stop_media=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 64
      ;;
    *)
      if [[ -n "$target" ]]; then
        echo "error: expected one Spotify URL, got extra argument: $1" >&2
        exit 64
      fi
      target="$1"
      shift
      ;;
  esac
done

if [[ -z "$target" && $# -gt 0 ]]; then
  target="$1"
  shift
fi

if [[ -z "$target" ]]; then
  echo "error: missing Spotify URL" >&2
  usage >&2
  exit 64
fi

if (($# > 0)); then
  echo "error: unexpected extra arguments: $*" >&2
  exit 64
fi

if [[ -z "$serial" ]]; then
  serial="$(require_tv_serial)"
fi

if [[ ! "$target" =~ ^https://open\.spotify\.com/ ]]; then
  echo "error: expected an https://open.spotify.com/... URL" >&2
  exit 64
fi

adb_args=()
if [[ -n "$serial" ]]; then
  adb_args=(-s "$serial")
fi

remote_quote() {
  printf "%q" "$1"
}

remote_command=$(
  printf "am start -a %s -d %s -p %s" \
    "$(remote_quote "android.intent.action.VIEW")" \
    "$(remote_quote "$target")" \
    "$(remote_quote "$package")"
)

command=(adb "${adb_args[@]}" shell "$remote_command")

if ((dry_run)); then
  if ((stop_media)); then
    "$script_dir/stop-media" "${adb_args[@]}" --dry-run
  fi
  printf 'DRY RUN: '
  printf '%q ' "${command[@]}"
  printf '\n'
  printf 'result=dry_run\n'
  exit 0
fi

if ! command -v adb >/dev/null 2>&1; then
  echo "error: adb is not installed or is not on PATH" >&2
  exit 69
fi

if ((stop_media)); then
  "$script_dir/stop-media" "${adb_args[@]}"
fi

"${command[@]}"
printf 'result=success\n'
