# Template only. Agents should normally populate ignored .env by running
# scripts/connect-tv and scripts/connect-sonos.

# Android TV / Shield ADB target. scripts/connect-tv can discover and save
# this in .tv-serial, so this is optional after first setup.
TV_ADB_SERIAL=TV_IP:5555

# IPv4 /24 prefix used by scripts/connect-tv when scanning for the Shield.
TV_SCAN_PREFIX=192.168.1

# Sonos speaker host for volume controls.
SONOS_HOST=SONOS_IP
SONOS_PORT=1400
SONOS_VOLUME_STEP=10
